{
  "name": "atlas-chat-exporter",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first toolkit for exporting Atlas/ChatGPT conversations via shared extraction core.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "release:prepare": "pnpm verify && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
