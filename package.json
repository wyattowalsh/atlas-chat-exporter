{
  "name": "atlas-chat-exporter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "fixtures:collect": "tsx scripts/collect-fixtures.ts",
    "fixtures:verify": "tsx scripts/verify-fixtures.ts",
    "build:snippets": "tsx scripts/bundle-snippets.ts",
    "build:bookmarklets": "tsx scripts/bundle-bookmarklets.ts",
    "build": "tsx scripts/build-all.ts",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm fixtures:verify && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.3.1",
    "esbuild": "^0.25.9",
    "eslint": "^9.35.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "tsx": "^4.20.5"
  }
}
