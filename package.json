{
  "name": "atlas-chat-exporter",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first toolkit for exporting Atlas/ChatGPT conversations with shared extraction core.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:all": "tsx scripts/build-all.ts",
    "test": "pnpm -r --if-present test && pnpm test:unit && pnpm test:golden && pnpm test:smoke",
    "test:unit": "vitest run tests/unit tests/failure",
    "test:golden": "vitest run tests/golden",
    "test:smoke": "vitest run tests/smoke",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "lint:fix": "pnpm lint -- --fix",
    "typecheck": "pnpm -r --if-present typecheck",
    "collect:fixtures": "tsx scripts/collect-fixtures.ts",
    "verify:fixtures": "tsx scripts/verify-fixtures.ts",
    "check:security-policy": "node scripts/enforce-security-policy.mjs",
    "package:extension": "tsx scripts/package-extension.ts",
    "package:release": "tsx scripts/package-release.ts",
    "bundle:snippets": "tsx scripts/bundle-snippets.ts",
    "bundle:bookmarklets": "tsx scripts/bundle-bookmarklets.ts",
    "ci": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:golden && pnpm test:smoke && pnpm verify:fixtures && pnpm check:security-policy && pnpm build",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "format": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/chrome": "^0.1.37",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
