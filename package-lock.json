{
  "name": "atlas-chat-exporter",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "atlas-chat-exporter",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "apps/*"
      ]
    },
    "apps/bookmarklets": {
      "name": "@atlas/bookmarklets",
      "version": "0.1.0"
    },
    "apps/cli": {
      "name": "@atlas/cli",
      "version": "0.1.0",
      "dependencies": {
        "@atlas/core": "0.1.0",
        "@atlas/shared": "0.1.0"
      },
      "bin": {
        "atlas-export": "src/cli.js"
      }
    },
    "apps/extension": {
      "name": "@atlas/extension",
      "version": "0.1.0",
      "dependencies": {
        "@atlas/core": "0.1.0",
        "@atlas/shared": "0.1.0"
      }
    },
    "apps/snippets": {
      "name": "@atlas/snippets",
      "version": "0.1.0"
    },
    "apps/userscript": {
      "name": "@atlas/userscript",
      "version": "0.1.0",
      "dependencies": {
        "@atlas/core": "0.1.0",
        "@atlas/shared": "0.1.0"
      }
    },
    "node_modules/@atlas/bookmarklets": {
      "resolved": "apps/bookmarklets",
      "link": true
    },
    "node_modules/@atlas/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@atlas/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@atlas/extension": {
      "resolved": "apps/extension",
      "link": true
    },
    "node_modules/@atlas/parser-dom": {
      "resolved": "packages/parser-dom",
      "link": true
    },
    "node_modules/@atlas/render-json": {
      "resolved": "packages/render-json",
      "link": true
    },
    "node_modules/@atlas/render-markdown": {
      "resolved": "packages/render-markdown",
      "link": true
    },
    "node_modules/@atlas/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@atlas/snippets": {
      "resolved": "apps/snippets",
      "link": true
    },
    "node_modules/@atlas/transform": {
      "resolved": "packages/transform",
      "link": true
    },
    "node_modules/@atlas/userscript": {
      "resolved": "apps/userscript",
      "link": true
    },
    "packages/core": {
      "name": "@atlas/core",
      "version": "0.1.0",
      "dependencies": {
        "@atlas/parser-dom": "0.1.0",
        "@atlas/render-json": "0.1.0",
        "@atlas/render-markdown": "0.1.0",
        "@atlas/shared": "0.1.0",
        "@atlas/transform": "0.1.0"
      }
    },
    "packages/parser-dom": {
      "name": "@atlas/parser-dom",
      "version": "0.1.0"
    },
    "packages/render-json": {
      "name": "@atlas/render-json",
      "version": "0.1.0"
    },
    "packages/render-markdown": {
      "name": "@atlas/render-markdown",
      "version": "0.1.0"
    },
    "packages/shared": {
      "name": "@atlas/shared",
      "version": "0.1.0"
    },
    "packages/transform": {
      "name": "@atlas/transform",
      "version": "0.1.0"
    }
  }
}
